# .gitignore

```gitignore
# Virtual environment
.venv/
venv/

# Python
__pycache__/
*.py[cod]
*$py.class

# Environment variables
.env

# IDEs
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Test & coverage
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/
```
